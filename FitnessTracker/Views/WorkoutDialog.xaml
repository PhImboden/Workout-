<Window x:Class="FitnessTracker.Views.WorkoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workout erstellen" Height="320" Width="450"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#0F1419"
        Foreground="#FFFFFF">
    
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#00BFA5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00897B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004D40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="CaretBrush" Value="#00BFA5"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="25">
        <!-- Title -->
        <TextBlock Text="✚ NEUES WORKOUT" FontSize="18" FontWeight="Bold" 
                   Foreground="#FFFFFF" Margin="0,0,0,25"/>

        <!-- Name Input -->
        <Border Background="#1E1E2E" Padding="15" CornerRadius="8" Margin="0,0,0,18"
                BorderThickness="1" BorderBrush="#2C2C3E">
            <StackPanel>
                <TextBlock Text="Workout Name" FontSize="11" FontWeight="Bold" 
                           Foreground="#00BFA5" Margin="0,0,0,10"/>
                <TextBox x:Name="NameTextBox" 
                         Style="{StaticResource DialogTextBox}"
                         Padding="12"
                         FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Date Input -->
        <Border Background="#1E1E2E" Padding="15" CornerRadius="8" Margin="0,0,0,25"
                BorderThickness="1" BorderBrush="#2C2C3E">
            <StackPanel>
                <TextBlock Text="Datum" FontSize="11" FontWeight="Bold" 
                           Foreground="#00BFA5" Margin="0,0,0,10"/>
                <DatePicker x:Name="DatePicker" 
                            Background="#252A35"
                            Foreground="#FFFFFF"
                            Padding="12"
                            FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Bottom Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" 
                    Background="#546E7A" Foreground="White"
                    Padding="15,10" 
                    Click="Cancel_Click" MinWidth="90"
                    Style="{StaticResource DialogButton}"
                    IsCancel="True"
                    Margin="0,0,12,0"/>
            <Button Content="✓ Erstellen" 
                    Style="{StaticResource SuccessButton}"
                    Padding="15,10" 
                    Click="OK_Click" MinWidth="110"
                    IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
