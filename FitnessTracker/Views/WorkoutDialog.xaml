<Window x:Class="FitnessTracker.Views.WorkoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workout" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#F5F5F5">
    <StackPanel Margin="20" VerticalAlignment="Top">
        <TextBlock Text="Workout Name:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="NameTextBox" 
                 Padding="8" 
                 Margin="0,0,0,15"
                 FontSize="12"/>

        <TextBlock Text="Datum:" FontWeight="Bold" Margin="0,0,0,5"/>
        <DatePicker x:Name="DatePicker" 
                    Padding="8" 
                    Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" 
                    Background="#007ACC" Foreground="White" 
                    Padding="15,10" Margin="0,0,10,0" 
                    Click="OK_Click" MinWidth="80"
                    IsDefault="True"/>
            <Button Content="Abbrechen" 
                    Background="#6C757D" Foreground="White" 
                    Padding="15,10" 
                    Click="Cancel_Click" MinWidth="80"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
