<Window x:Class="FitnessTracker.Views.ExerciseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Übung hinzufügen" Height="700" Width="550"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#0F1419"
        Foreground="#FFFFFF">
    
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#00BFA5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00897B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004D40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="CaretBrush" Value="#00BFA5"/>
        </Style>

        <Style x:Key="DialogComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0F1419">
        <StackPanel Margin="25">
            <!-- Title -->
            <TextBlock Text="🏋️ ÜBUNG HINZUFÜGEN" FontSize="18" FontWeight="Bold" 
                       Foreground="#FFFFFF" Margin="0,0,0,25"/>

            <!-- Section 1: Exercise Selection -->
            <Border Background="#1E1E2E" Padding="18" CornerRadius="8" Margin="0,0,0,20"
                    BorderThickness="1" BorderBrush="#2C2C3E">
                <StackPanel>
                    <TextBlock Text="📋 Übung auswählen" FontSize="12" FontWeight="Bold" 
                               Foreground="#00BFA5" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Aus Katalog:" FontSize="11" FontWeight="SemiBold" 
                               Foreground="#B0BEC5" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ExerciseCombo" 
                              Style="{StaticResource DialogComboBox}"
                              Margin="0,0,0,15"
                              DisplayMemberPath="Name"
                              Padding="12"/>

                    <TextBlock Text="oder eingeben:" FontSize="11" FontWeight="SemiBold" 
                               Foreground="#B0BEC5" Margin="0,0,0,8"/>
                    <TextBox x:Name="CustomExerciseText" 
                             Style="{StaticResource DialogTextBox}"
                             Margin="0,0,0,0"
                             Padding="12"/>
                </StackPanel>
            </Border>

            <!-- Section 2: Muscle Group -->
            <Border Background="#1E1E2E" Padding="18" CornerRadius="8" Margin="0,0,0,20"
                    BorderThickness="1" BorderBrush="#2C2C3E">
                <StackPanel>
                    <TextBlock Text="💪 Muskelgruppe" FontSize="12" FontWeight="Bold" 
                               Foreground="#00BFA5" Margin="0,0,0,10"/>
                    
                    <ComboBox x:Name="MuscleCombo" 
                              Style="{StaticResource DialogComboBox}"
                              Padding="12"/>
                </StackPanel>
            </Border>

            <!-- Section 3: Sets -->
            <Border Background="#1E1E2E" Padding="18" CornerRadius="8" Margin="0,0,0,20"
                    BorderThickness="1" BorderBrush="#2C2C3E">
                <StackPanel>
                    <TextBlock Text="⚙️ SETS" FontSize="12" FontWeight="Bold" 
                               Foreground="#00BFA5" Margin="0,0,0,12"/>

                    <!-- Sets Header -->
                    <Border Background="#0F1419" Padding="10,8" CornerRadius="4" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Set" FontWeight="Bold" Width="30" 
                                       Foreground="#90A4AE" FontSize="10"/>
                            <TextBlock Text="Wiederh." FontWeight="Bold" Width="70" 
                                       Foreground="#90A4AE" FontSize="10" Margin="10,0,0,0"/>
                            <TextBlock Text="Gewicht (kg)" FontWeight="Bold" Width="80" 
                                       Foreground="#90A4AE" FontSize="10" Margin="10,0,0,0"/>
                            <TextBlock Text="" Width="40" Foreground="#90A4AE" FontSize="10"/>
                        </StackPanel>
                    </Border>

                    <!-- Sets ListBox -->
                    <ListBox x:Name="SetsList" 
                             Background="#0F1419" 
                             Margin="0,0,0,12" 
                             MinHeight="120" 
                             MaxHeight="220"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252A35" Padding="8" CornerRadius="4" 
                                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#2C2C3E">
                                    <StackPanel Orientation="Horizontal" Margin="0">
                                        <TextBlock Text="{Binding SetNumber}" Width="30" 
                                                   VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold"/>
                                        <TextBox Text="{Binding Reps, UpdateSourceTrigger=PropertyChanged}" 
                                                 Width="60" Margin="10,0,0,0" Padding="8"
                                                 Style="{StaticResource DialogTextBox}"/>
                                        <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" 
                                                 Width="70" Margin="10,0,0,0" Padding="8"
                                                 Style="{StaticResource DialogTextBox}"/>
                                        <Button Content="✕" Width="35" Margin="10,0,0,0" 
                                                Background="#D32F2F" Foreground="White"
                                                Click="RemoveSet_Click" Tag="{Binding}"
                                                Style="{StaticResource DialogButton}"
                                                Padding="6,4" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add Set Button -->
                    <Button Content="✚ Set hinzufügen" 
                            Background="#1976D2" Foreground="White"
                            Padding="10,8" 
                            Click="AddSet_Click" 
                            FontSize="11"
                            Height="36"
                            Style="{StaticResource DialogButton}"/>
                </StackPanel>
            </Border>

            <!-- Volume Info -->
            <Border Background="#263238" Padding="15" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚖️ Gesamt-Volumen:" FontWeight="Bold" 
                               Foreground="#B0BEC5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="VolumeInfo" Text="0 kg" FontSize="13" 
                               Foreground="#00BFA5" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Bottom Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Abbrechen" 
                        Background="#546E7A" Foreground="White"
                        Padding="15,10" 
                        Click="Cancel_Click" MinWidth="90"
                        Style="{StaticResource DialogButton}"
                        IsCancel="True"
                        Margin="0,0,12,0"/>
                <Button Content="✓ OK" 
                        Style="{StaticResource SuccessButton}"
                        Padding="15,10" 
                        Click="OK_Click" MinWidth="90"
                        IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
