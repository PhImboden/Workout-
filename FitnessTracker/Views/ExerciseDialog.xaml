<Window x:Class="FitnessTracker.Views.ExerciseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Übung hinzufügen" Height="600" Width="500"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Exercise Selection -->
            <TextBlock Text="Übung wählen:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="ExerciseCombo" 
                      Padding="8" 
                      Margin="0,0,0,15"
                      DisplayMemberPath="Name"/>

            <!-- Alternative: Custom Exercise -->
            <TextBlock Text="oder eigene Übung:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="CustomExerciseText" 
                     Padding="8" 
                     Margin="0,0,0,10"/>

            <!-- Muscle Group -->
            <TextBlock Text="Muskelgruppe:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="MuscleCombo" 
                      Padding="8" 
                      Margin="0,0,0,15"/>

            <!-- Sets Section -->
            <TextBlock Text="Sets:" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
            <Border Background="#FFFFFF" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Set" FontWeight="Bold" Width="40"/>
                        <TextBlock Text="Wiederholungen" FontWeight="Bold" Width="120" Margin="10,0,0,0"/>
                        <TextBlock Text="Gewicht (kg)" FontWeight="Bold" Width="100" Margin="10,0,0,0"/>
                        <TextBlock Text="" Width="40"/>
                    </StackPanel>

                    <!-- Sets ListBox -->
                    <ListBox x:Name="SetsList" 
                             Background="#F9F9F9" 
                             Margin="0,0,0,10" 
                             MinHeight="150" 
                             MaxHeight="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding SetNumber}" Width="40" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding Reps, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="120" Margin="10,0,0,0" Padding="5" />
                                    <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="100" Margin="10,0,0,0" Padding="5" />
                                    <Button Content="✕" Width="30" Margin="10,0,0,0" 
                                            Background="#DC3545" Foreground="White"
                                            Click="RemoveSet_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add Set Button -->
                    <Button Content="+ Set hinzufügen" 
                            Background="#28A745" Foreground="White" 
                            Padding="8" 
                            Click="AddSet_Click" 
                            FontSize="11"
                            Height="32"/>
                </StackPanel>
            </Border>

            <!-- Info -->
            <TextBlock Text="Gesamt-Volumen: " FontWeight="Bold" FontSize="11" Margin="0,0,0,3"/>
            <TextBlock x:Name="VolumeInfo" Text="0 kg" FontSize="11" Foreground="#666" Margin="0,0,0,15"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" 
                        Background="#007ACC" Foreground="White" 
                        Padding="15,10" Margin="0,0,10,0" 
                        Click="OK_Click" MinWidth="80"
                        IsDefault="True"/>
                <Button Content="Abbrechen" 
                        Background="#6C757D" Foreground="White" 
                        Padding="15,10" 
                        Click="Cancel_Click" MinWidth="80"
                        IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
