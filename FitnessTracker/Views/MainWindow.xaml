<Window x:Class="FitnessTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fitness Tracker" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#00BFA5"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#D32F2F"/>
        </Style>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="CaretBrush" Value="#00BFA5"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Background="#1E1E2E">
            <Border Background="#121619" Padding="20">
                <StackPanel>
                    <TextBlock Text="💪 FITNESS" FontSize="16" FontWeight="Bold" Foreground="#00BFA5" Margin="0,0,0,5"/>
                    <TextBlock Text="Trainiere smart" FontSize="11" Foreground="#B0BEC5" FontStyle="Italic"/>
                </StackPanel>
            </Border>
            <StackPanel Margin="15,15,15,10">
                <TextBlock Text="Suche" FontSize="11" FontWeight="Bold" Foreground="#90A4AE" Margin="0,0,0,8"/>
                <TextBox x:Name="SearchBox" Style="{StaticResource ModernTextBox}" TextChanged="SearchBox_TextChanged" Margin="0,0,0,15" Padding="12"/>
            </StackPanel>
            <StackPanel Margin="15,0,15,15">
                <TextBlock Text="Filter" FontSize="11" FontWeight="Bold" Foreground="#90A4AE" Margin="0,0,0,10"/>
                <RadioButton x:Name="RadioAll" Content="Alle" IsChecked="True" Checked="FilterRadio_Changed" Foreground="#FFFFFF" FontSize="12" Margin="0,0,0,8"/>
                <RadioButton x:Name="RadioOpen" Content="Aktiv" Checked="FilterRadio_Changed" Foreground="#FFFFFF" FontSize="12" Margin="0,0,0,8"/>
                <RadioButton x:Name="RadioCompleted" Content="Erledigt" Checked="FilterRadio_Changed" Foreground="#FFFFFF" FontSize="12"/>
            </StackPanel>
            <Button Content="✚ Neues Workout" Style="{StaticResource PrimaryButton}" Padding="12,12" Margin="15,0,15,15" Click="NewWorkout_Click" FontWeight="Bold" Height="45" FontSize="13"/>
            <ListBox x:Name="WorkoutsList" Background="#1E1E2E" SelectionChanged="WorkoutsList_SelectionChanged" Margin="0" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#2C2C3E" Padding="15,12" Background="#252A35">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFFFFF" FontSize="13"/>
                                <TextBlock Text="{Binding Date, StringFormat='📅 {0:dd.MM.yyyy}'}" FontSize="10" Foreground="#90A4AE" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#0F1419">
            <StackPanel Margin="30,25,30,30">
                <TextBlock x:Name="WorkoutTitle" Text="Kein Workout ausgewählt" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,15"/>
                <Border Background="#1E1E2E" Padding="20" CornerRadius="8" Margin="0,0,0,25" BorderThickness="1" BorderBrush="#2C2C3E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="Datum" FontSize="10" Foreground="#90A4AE" FontWeight="Bold" Margin="0,0,0,6"/><TextBlock x:Name="WorkoutDate" Text="-" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold"/></StackPanel>
                        <StackPanel Grid.Column="1" Margin="15,0,0,0"><TextBlock Text="Status" FontSize="10" Foreground="#90A4AE" FontWeight="Bold" Margin="0,0,0,6"/><TextBlock x:Name="WorkoutStatus" Text="-" FontSize="14" Foreground="#00BFA5" FontWeight="SemiBold"/></StackPanel>
                        <StackPanel Grid.Column="2" Margin="15,0,0,0"><TextBlock Text="Übungen" FontSize="10" Foreground="#90A4AE" FontWeight="Bold" Margin="0,0,0,6"/><TextBlock x:Name="ExerciseCount" Text="-" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold"/></StackPanel>
                        <StackPanel Grid.Column="3" Margin="15,0,0,0"><TextBlock Text="Volumen" FontSize="10" Foreground="#90A4AE" FontWeight="Bold" Margin="0,0,0,6"/><TextBlock x:Name="TotalVolume" Text="-" FontSize="14" Foreground="#00BFA5" FontWeight="Bold"/></StackPanel>
                    </Grid>
                </Border>
                <TextBlock Text="ÜBUNGEN" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                <ListBox x:Name="ExercisesList" Background="#0F1419" Margin="0,0,0,20" MinHeight="100" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E2E" Padding="15" CornerRadius="6" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#2C2C3E">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="13" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Muscle}" Foreground="#00BFA5" FontSize="10" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Sets.Count, StringFormat='Sets: {0}'}" FontSize="10" Foreground="#90A4AE" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Bearbeiten" Style="{StaticResource ModernButton}" Click="EditExercise_Click" Padding="8,4" FontSize="10" Margin="0,0,8,0"/>
                                        <Button Content="Löschen" Style="{StaticResource DangerButton}" Click="DeleteExercise_Click" Padding="8,4" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="✚ Übung hinzufügen" Style="{StaticResource PrimaryButton}" Padding="12,12" Margin="0,0,0,20" Click="AddExercise_Click" FontWeight="Bold" Height="40" FontSize="12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Bearbeiten" Style="{StaticResource ModernButton}" Padding="12,10" Click="EditWorkout_Click" MinWidth="100" Height="40" FontSize="12" Margin="0,0,10,0"/>
                    <Button Content="Erledigt" Style="{StaticResource PrimaryButton}" Padding="12,10" Click="CompleteWorkout_Click" MinWidth="100" Height="40" x:Name="CompleteButton" FontSize="12" Margin="0,0,10,0"/>
                    <Button Content="Löschen" Style="{StaticResource DangerButton}" Padding="12,10" Click="DeleteWorkout_Click" MinWidth="100" Height="40" FontSize="12"/>
                </StackPanel>
                <TextBlock x:Name="EmptyMessage" Text="Wähle ein Workout aus" Foreground="#616161" FontSize="12" TextAlignment="Center" Margin="0,30,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
