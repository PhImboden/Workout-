<Window x:Class="FitnessTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fitness Tracker" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Workouts List -->
        <StackPanel Grid.Column="0" Background="#FFFFFF" Margin="0">
            <Border Background="#007ACC" Padding="10" Margin="0,0,0,10">
                <TextBlock Text="Fitness Tracker" FontSize="18" FontWeight="Bold" Foreground="White"/>
            </Border>

            <!-- Search & Filter -->
            <StackPanel Margin="10">
                <TextBlock Text="Suchen:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SearchBox" 
                         Padding="8" 
                         TextChanged="SearchBox_TextChanged"
                         Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="RadioAll" Content="Alle" IsChecked="True" 
                                 Checked="FilterRadio_Changed" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RadioOpen" Content="Offen" 
                                 Checked="FilterRadio_Changed" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RadioCompleted" Content="Erledigt" 
                                 Checked="FilterRadio_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- New Workout Button -->
            <Button Content="+ Neues Workout" 
                    Background="#28A745" Foreground="White" 
                    Padding="10" Margin="10,0,10,10" 
                    Click="NewWorkout_Click" FontWeight="Bold" Height="40"/>

            <!-- Workouts ListBox -->
            <ListBox x:Name="WorkoutsList" 
                     Background="#F5F5F5" 
                     SelectionChanged="WorkoutsList_SelectionChanged"
                     Margin="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#DDD" Padding="10,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" 
                                               Foreground="#000"/>
                                    <TextBlock Text="✓" Foreground="#28A745" FontSize="14" 
                                               Margin="10,0,0,0" 
                                               Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisConverter}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}" 
                                           FontSize="11" Foreground="#666"/>
                                <TextBlock Text="{Binding Exercises.Count, StringFormat='Übungen: {0}'}" 
                                           FontSize="10" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Right Panel: Workout Details -->
        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock x:Name="WorkoutTitle" Text="Kein Workout ausgewählt" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Workout Info -->
                    <Border Background="#E7F3FF" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Datum:" FontWeight="Bold" Width="80"/>
                                <TextBlock x:Name="WorkoutDate" Text="-"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Status:" FontWeight="Bold" Width="80"/>
                                <TextBlock x:Name="WorkoutStatus" Text="-"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Gesamtvolumen:" FontWeight="Bold" Width="80"/>
                                <TextBlock x:Name="TotalVolume" Text="-"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Exercises Section -->
                    <TextBlock Text="Übungen" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ListBox x:Name="ExercisesList" 
                             Background="#F9F9F9" 
                             Margin="0,0,0,10" 
                             MinHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" BorderBrush="#DDD" Padding="10,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" 
                                                       Width="150"/>
                                            <TextBlock Text="{Binding Muscle}" Foreground="#666" 
                                                       Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Sets.Count, StringFormat='Sätze: {0}'}" 
                                                   FontSize="10" Foreground="#999"/>
                                        <TextBlock FontSize="10" Foreground="#666">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="Volumen: {0:F1} kg">
                                                    <Binding Path="." Converter="{StaticResource VolumeConverter}"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        
                                        <!-- Sets Details -->
                                        <ItemsControl ItemsSource="{Binding Sets}" Margin="0,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="9" Foreground="#999" Margin="0,2,0,0">
                                                        <Run Text="Satz: "/>
                                                        <Run Text="{Binding Reps, Mode=OneWay}"/> <Run Text="x "/>
                                                        <Run Text="{Binding Weight, Mode=OneWay, StringFormat='{0:F1}'}" /> <Run Text="kg"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Exercise Action Buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Button Content="✎ Bearbeiten" 
                                                    Background="#007ACC" Foreground="White" 
                                                    Padding="5,3" Margin="0,0,5,0" FontSize="10"
                                                    Click="EditExercise_Click" MinWidth="70"/>
                                            <Button Content="✕ Löschen" 
                                                    Background="#DC3545" Foreground="White" 
                                                    Padding="5,3" FontSize="10"
                                                    Click="DeleteExercise_Click" MinWidth="70"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add Exercise Button -->
                    <Button Content="+ Übung hinzufügen" 
                            Background="#28A745" Foreground="White" 
                            Padding="10" Margin="0,0,0,10" 
                            Click="AddExercise_Click" 
                            FontWeight="Bold" Height="40"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="✎ Bearbeiten" 
                                Background="#007ACC" Foreground="White" 
                                Padding="10" Margin="0,0,10,0" 
                                Click="EditWorkout_Click" MinWidth="100"/>
                        <Button Content="✓ Erledigt" 
                                Background="#28A745" Foreground="White" 
                                Padding="10" Margin="0,0,10,0" 
                                Click="CompleteWorkout_Click" MinWidth="100"
                                x:Name="CompleteButton"/>
                        <Button Content="🗑 Löschen" 
                                Background="#DC3545" Foreground="White" 
                                Padding="10" 
                                Click="DeleteWorkout_Click" MinWidth="100"/>
                    </StackPanel>

                    <!-- Empty State -->
                    <TextBlock x:Name="EmptyMessage" 
                               Text="Wähle ein Workout aus oder erstelle ein neues Workout" 
                               Foreground="#999" 
                               FontSize="12" 
                               TextAlignment="Center"
                               Margin="0,20"/>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
